# ── Integração Microsoft 365 ──────────────────────────────────────
# Como configurar:
# 1. Acesse https://portal.azure.com > Azure Active Directory > Registros de aplicativo
# 2. Clique em "Novo registro"
#    - Nome: Rotina (ou qualquer nome)
#    - Tipos de conta: "Contas em qualquer diretório organizacional e contas Microsoft pessoais"
#    - URI de redirecionamento: Web > http://localhost:3001/api/ms/callback
# 3. Copie o "ID do aplicativo (cliente)" → MS_CLIENT_ID
# 4. Vá em "Certificados e segredos" > "Novo segredo do cliente" → MS_CLIENT_SECRET
# 5. Vá em "Permissões de API" e adicione (Microsoft Graph, Delegado):
#    - User.Read
#    - Calendars.Read
# 6. Renomeie este arquivo para .env e preencha os valores abaixo

MS_CLIENT_ID=cole_o_client_id_aqui
MS_CLIENT_SECRET=cole_o_client_secret_aqui
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:3001/api/ms/callback
FRONTEND_URL=http://localhost:3000

# ── Integração Telegram ───────────────────────────────────────────
# Como configurar:
# 1. Abra o Telegram e converse com @BotFather
# 2. Envie /newbot, escolha um nome e um username (termina em _bot)
# 3. Copie o token gerado → TELEGRAM_BOT_TOKEN
# 4. Para descobrir seu Chat ID: envie uma mensagem para o bot,
#    depois acesse https://api.telegram.org/bot<TOKEN>/getUpdates
#    e copie o "id" dentro de "chat"
# 5. Execute o bot: python telegram_bot.py

TELEGRAM_BOT_TOKEN=8760746174:AAHU7bweWGY6Xk_72gAj_Mbe7esyJ6Ot3RY
TELEGRAM_CHAT_ID=6789124189
